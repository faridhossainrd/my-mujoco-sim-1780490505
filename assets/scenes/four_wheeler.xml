<?xml version="1.0"?>
<mujoco model="four_wheeler">
  <option timestep="0.01"/>
  <default>
    <joint limited="false"/>
    <geom contype="0" conaffinity="0"/>
  </default>
  <worldbody>
    <light pos="0 0 1" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="10 10 0.1" rgba="0.9 0.9 0.9 1"/>
    <body name="chassis" pos="0 0 0.02">
      <!-- main chassis -->
      <geom name="chassis_main" type="box" size="0.8 0.3 0.02" rgba="0.1 0.2 0.5 1" mass="5"/>
      <!-- cabin -->
      <geom name="cabin" type="box" size="0.35 0.2 0.04" pos="0 0 0.06" rgba="0.8 0.8 0.9 1"/>
      <!-- hood -->
      <geom name="hood" type="box" size="0.3 0.25 0.015" pos="0.25 0 0.035" rgba="0.1 0.2 0.5 1"/>
      <!-- spoiler -->
      <geom name="spoiler" type="box" size="0.25 0.05 0.005" pos="-0.35 0 0.08" rgba="0.1 0.1 0.1 1"/>
      <!-- front left wheel -->
      <body name="fl_wheel" pos="-0.35 0.2 -0.02">
        <!-- tire -->
        <geom name="fl_tire" type="cylinder" size="0.09 0.03" rgba="0.05 0.05 0.05 1"/>
        <!-- rim -->
        <geom name="fl_rim" type="cylinder" size="0.05 0.025" pos="0 0 0" rgba="0.7 0.7 0.7 1"/>
        <joint name="fl_hinge" axis="0 1 0" type="hinge"/>
      </body>
      <!-- front right wheel -->
      <body name="fr_wheel" pos="-0.35 -0.2 -0.02">
        <geom name="fr_tire" type="cylinder" size="0.09 0.03" rgba="0.05 0.05 0.05 1"/>
        <geom name="fr_rim" type="cylinder" size="0.05 0.025" pos="0 0 0" rgba="0.7 0.7 0.7 1"/>
        <joint name="fr_hinge" axis="0 1 0" type="hinge"/>
      </body>
      <!-- rear left wheel -->
      <body name="rl_wheel" pos="0.35 0.2 -0.02">
        <geom name="rl_tire" type="cylinder" size="0.09 0.03" rgba="0.05 0.05 0.05 1"/>
        <geom name="rl_rim" type="cylinder" size="0.05 0.025" pos="0 0 0" rgba="0.7 0.7 0.7 1"/>
        <joint name="rl_hinge" axis="0 1 0" type="hinge"/>
      </body>
      <!-- rear right wheel -->
      <body name="rr_wheel" pos="0.35 -0.2 -0.02">
        <geom name="rr_tire" type="cylinder" size="0.09 0.03" rgba="0.05 0.05 0.05 1"/>
        <geom name="rr_rim" type="cylinder" size="0.05 0.025" pos="0 0 0" rgba="0.7 0.7 0.7 1"/>
        <joint name="rr_hinge" axis="0 1 0" type="hinge"/>
      </body>
    </body>
  </worldbody>
  <actuator>
    <motor joint="fl_hinge" ctrlrange="-1 1" ctrllimited="true"/>
    <motor joint="fr_hinge" ctrlrange="-1 1" ctrllimited="true"/>
    <motor joint="rl_hinge" ctrlrange="-1 1" ctrllimited="true"/>
    <motor joint="rr_hinge" ctrlrange="-1 1" ctrllimited="true"/>
  </actuator>
</mujoco>