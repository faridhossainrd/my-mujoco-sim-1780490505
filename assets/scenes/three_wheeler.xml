<mujoco model="three_wheeler">
  <option timestep="0.005" gravity="0 0 -9.81"/>

  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.7 0.7 0.7" rgb2="0.5 0.5 0.5" width="512" height="512"/>
    <material name="grid_mat" texture="grid" texrepeat="4 4" reflectance="0.2"/>
    <material name="body_mat" rgba="0.2 0.5 0.9 1"/>
    <material name="wheel_mat" rgba="0.15 0.15 0.15 1"/>
    <material name="front_mat" rgba="0.9 0.4 0.1 1"/>
  </asset>

  <worldbody>
    <light name="sun" pos="0 0 10" dir="0 0 -1" diffuse="1 1 1" specular="0.3 0.3 0.3" castshadow="true"/>
    <geom name="floor" type="plane" size="50 50 0.1" material="grid_mat" friction="1.2 0.05 0.05"/>

    <body name="chassis" pos="0 0 0.35">
      <freejoint name="root"/>
      <geom name="chassis_body" type="box" size="0.45 0.22 0.08" material="body_mat" mass="6"/>
      <geom name="cabin" type="box" size="0.2 0.18 0.1" pos="0.05 0 0.18" material="body_mat" mass="1"/>

      <!-- Rear Left Wheel -->
      <body name="rear_left_wheel" pos="-0.35 0.26 -0.05">
        <joint name="rear_left_spin" type="hinge" axis="0 1 0" limited="false"/>
        <geom name="rear_left_geom" type="cylinder" size="0.12 0.05" euler="90 0 0" material="wheel_mat" mass="0.8" friction="1.5 0.05 0.05"/>
      </body>

      <!-- Rear Right Wheel -->
      <body name="rear_right_wheel" pos="-0.35 -0.26 -0.05">
        <joint name="rear_right_spin" type="hinge" axis="0 1 0" limited="false"/>
        <geom name="rear_right_geom" type="cylinder" size="0.12 0.05" euler="90 0 0" material="wheel_mat" mass="0.8" friction="1.5 0.05 0.05"/>
      </body>

      <!-- Front Wheel (steering + drive) -->
      <body name="front_steer_body" pos="0.38 0 -0.05">
        <joint name="front_steer" type="hinge" axis="0 0 1" range="-0.6 0.6"/>
        <body name="front_wheel_body" pos="0 0 0">
          <joint name="front_spin" type="hinge" axis="0 1 0" limited="false"/>
          <geom name="front_geom" type="cylinder" size="0.12 0.05" euler="90 0 0" material="front_mat" mass="0.8" friction="1.5 0.05 0.05"/>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <velocity name="drive_rear_left"  joint="rear_left_spin"  kv="8" gear="1"/>
    <velocity name="drive_rear_right" joint="rear_right_spin" kv="8" gear="1"/>
    <velocity name="drive_front"      joint="front_spin"      kv="8" gear="1"/>
    <position name="steer_front"      joint="front_steer"     kp="30" gear="1"/>
  </actuator>

</mujoco>
